    { "type": "assistant", "text": "I'll locate the composer submit handler and wire in a short WebAudio blip." },
    {
      "type": "tool", "verb": "Ran", "label": "Grep onSubmit in composer",
      "detail": { "head": "src/composer.tsx", "lines": [
        { "t": "$ grep -n onSubmit src/composer.tsx", "kind": null },
        { "t": "42: const onSubmit = () => send(value)", "kind": null }
      ] }
    },
    {
      "type": "tool", "verb": "Ran", "label": "Edit composer.tsx",
      "detail": { "head": "src/composer.tsx", "lines": [
        { "t": "  const onSubmit = () => {", "kind": null },
        { "t": "+   playBlip();", "kind": "add" },
        { "t": "    send(value);", "kind": null },
        { "t": "  };", "kind": null }
      ] }
    },
    {
      "type": "askq", "chip": "sound style", "question": "Which submit sound should I use?", "multi": false,
      "options": [
        { "label": "Soft blip", "desc": "220Hz sine, 60ms fade", "selected": true },
        { "label": "Mechanical click", "desc": "filtered noise burst" },
        { "label": "None", "desc": "keep it silent" }
      ]
    },
    { "type": "tool", "verb": "Running", "label": "Run test suite" },
    { "type": "status", "elapsed": "2 tool calls", "tasks": 1 }
  ]
}
