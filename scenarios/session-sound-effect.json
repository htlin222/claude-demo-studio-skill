{
  "surface": "code-session",
  "theme": "light",
  "sessionTitle": "Add sound effect for prompt input",
  "model": "Opus 4.8",
  "effort": "High",
  "mode": "Bypass permissions",
  "turnGapMs": 650,
  "recents": ["Add sound effect for prompt input", "iguana-quiet-candle", "vm-lazy-lightning"],
  "turns": [
